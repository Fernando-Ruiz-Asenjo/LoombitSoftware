# Loombit Operator — configuración local
# Copia este fichero a .env y rellena los valores reales.
# NUNCA subas .env al repo.

# ── Runtime ──────────────────────────────────────────────
LOOMBIT_OPERATOR_ENVIRONMENT=local
LOOMBIT_OPERATOR_LOG_LEVEL=INFO
LOOMBIT_OPERATOR_RUNTIME_MODE=development

# ── LLM — rol instructor (Qwen2.5-7B en LM Studio) ──────
LOOMBIT_OPERATOR_LLM_PROVIDER=lm_studio
LOOMBIT_OPERATOR_LLM_BASE_URL=http://localhost:1234/v1
LOOMBIT_OPERATOR_LLM_MODEL_NAME=qwen2.5-7b-instruct-1m

LOOMBIT_OPERATOR_LLM_INSTRUCTOR_PROVIDER=lm_studio
LOOMBIT_OPERATOR_LLM_INSTRUCTOR_BASE_URL=http://localhost:1234/v1
LOOMBIT_OPERATOR_LLM_INSTRUCTOR_MODEL_NAME=qwen2.5-7b-instruct-1m

# ── LLM — rol coder (Qwen2.5-Coder-7B en LM Studio) ─────
# Cambia el puerto si tienes el coder en una instancia separada de LM Studio.
LOOMBIT_OPERATOR_LLM_CODER_PROVIDER=lm_studio
LOOMBIT_OPERATOR_LLM_CODER_BASE_URL=http://localhost:1234/v1
LOOMBIT_OPERATOR_LLM_CODER_MODEL_NAME=qwen2.5-coder-7b-instruct

# ── LLM — parámetros generales ───────────────────────────
LOOMBIT_OPERATOR_LLM_TEMPERATURE=0.2
LOOMBIT_OPERATOR_LLM_MAX_TOKENS=512
LOOMBIT_OPERATOR_LLM_REQUEST_TIMEOUT_SECONDS=30.0

# ── Conectores Google OAuth (Fase 1) ──────────────────────
# Crea las credenciales OAuth en Google Cloud Console y pega client_id y
# client_secret EN TU .env local (NUNCA en este .env.example).
# APIs a habilitar en el proyecto: Gmail API, Google Calendar API, People API.
# El redirect_uri debe estar registrado tal cual en la consola de Google.
LOOMBIT_OPERATOR_SKILL_BLANCA_GOOGLE_OAUTH_ENABLED=false
LOOMBIT_OPERATOR_SKILL_BLANCA_GOOGLE_CLIENT_ID=
LOOMBIT_OPERATOR_SKILL_BLANCA_GOOGLE_CLIENT_SECRET=
LOOMBIT_OPERATOR_SKILL_BLANCA_GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/skill-blanca/oauth/google/callback
LOOMBIT_OPERATOR_SKILL_BLANCA_GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/contacts.readonly

# ── Conectores Microsoft OAuth (dejar vacío hasta Fase 1)
LOOMBIT_OPERATOR_SKILL_BLANCA_MICROSOFT_OAUTH_ENABLED=false
LOOMBIT_OPERATOR_SKILL_BLANCA_MICROSOFT_CLIENT_ID=
LOOMBIT_OPERATOR_SKILL_BLANCA_MICROSOFT_CLIENT_SECRET=
LOOMBIT_OPERATOR_SKILL_BLANCA_MICROSOFT_REDIRECT_URI=http://127.0.0.1:8787/skill-blanca/oauth/microsoft/callback

# ── Escritura de conectores (desactivada por defecto) ────
LOOMBIT_OPERATOR_SKILL_BLANCA_CONNECTOR_WRITES_ENABLED=false
LOOMBIT_OPERATOR_SKILL_BLANCA_EMAIL_DELIVERY_MODE=disabled
LOOMBIT_OPERATOR_SKILL_BLANCA_CALENDAR_DELIVERY_MODE=disabled
