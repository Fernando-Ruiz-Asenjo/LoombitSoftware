# Normalize line endings: LF in the repo, native on checkout.
* text=auto eol=lf

# Scripts that must keep platform-native endings
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh  text eol=lf

# Binary assets — never normalize or diff
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.exe binary
